{
  "name": "typo3-incubator/smart-search",
  "description": "Generic vector embedding, semantic search and RAG infrastructure for TYPO3",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.4",
    "typo3/cms-core": "^14"
  },
  "autoload": {
    "psr-4": {
      "TYPO3Incubator\\SmartSearch\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TYPO3Incubator\\SmartSearch\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "smart-search"
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  }
}
